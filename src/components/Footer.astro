---
---

<footer class="bg-[#121212] text-[#FDFBF7] pt-24 pb-8 border-t border-stone-800">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 mb-20">
      
      <div class="md:col-span-4 space-y-6">
        <span class="font-serif text-3xl tracking-wide block">Castello di Muggia</span>
        <p class="text-stone-400 font-light leading-relaxed max-w-sm">
          Un monumento vivo, affacciato sul Golfo di Trieste. Luogo di incontro, cultura ed esperienze senza tempo.
        </p>
      </div>

      <div class="md:col-span-2">
        <h4 class="text-[#A44B2B] text-xs uppercase tracking-widest font-bold mb-6">Il Castello</h4>
        <ul class="space-y-4 text-sm text-stone-300 font-light">
          <li><a href="#storia" class="hover:text-white transition-colors">La Storia</a></li>
          <li><a href="#restauro" class="hover:text-white transition-colors">Il Restauro</a></li>
          <li><a href="#galleria" class="hover:text-white transition-colors">Galleria</a></li>
        </ul>
      </div>

      <div class="md:col-span-2">
        <h4 class="text-[#A44B2B] text-xs uppercase tracking-widest font-bold mb-6">Informazioni</h4>
        <ul class="space-y-4 text-sm text-stone-300 font-light">
          <li><a href="#faq" class="hover:text-white transition-colors">FAQ</a></li>
          <li><a href="#privacy" class="hover:text-white transition-colors">Privacy Policy</a></li>
        </ul>
      </div>

      <div class="md:col-span-4">
        <h4 class="text-[#A44B2B] text-xs uppercase tracking-widest font-bold mb-6">Resta Aggiornato</h4>
        <p class="text-stone-400 text-sm font-light mb-4">Iscriviti per ricevere anticipazioni sugli eventi e l'apertura ufficiale.</p>
        <form class="flex gap-2">
          <input 
            type="email" 
            placeholder="Indirizzo Email" 
            required
            class="bg-stone-900 border border-stone-800 text-white px-4 py-3 rounded-xl focus:outline-none focus:border-[#A44B2B] w-full text-sm placeholder-stone-500 transition-colors"
          />
          <button type="submit" class="bg-[#A44B2B] hover:bg-[#8A3F24] text-white px-6 py-3 rounded-xl font-semibold transition-colors">
            Iscriviti
          </button>
        </form>
      </div>

    </div>

    <div class="pt-8 border-t border-stone-800/50 flex justify-between items-center text-xs text-stone-500 font-light">
      <p>&copy; 2026 Castello di Muggia.</p>
      <p>Astro SSR & Tailwind</p>
    </div>
  </div>
</footer>
