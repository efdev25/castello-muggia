---
---

<section id="galleria" class="py-24 bg-stone-100">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
      <div>
        <span class="text-[#A44B2B] text-sm uppercase tracking-widest font-semibold mb-4 block">Archivio Visivo</span>
        <h2 class="text-4xl md:text-5xl font-serif text-[#121212]">
          Bellezza conservata.
        </h2>
      </div>
      <p class="text-stone-600 max-w-md font-light">
        Esplora gli spazi del Castello. Dai saloni affrescati fino alle terrazze panoramiche che abbracciano il Golfo.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 md:grid-rows-2 gap-4 h-auto md:h-[600px]">
      <div class="md:col-span-2 md:row-span-2 relative rounded-3xl overflow-hidden group bg-stone-300 min-h-[300px]">
        <img 
          src="/images/castle_exterior.png" 
          alt="Cortile del castello" 
          class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-8">
          <p class="text-white font-serif text-2xl">Mura Antiche e Golfo</p>
        </div>
      </div>

      <div class="relative rounded-3xl overflow-hidden group bg-stone-300 min-h-[200px]">
        <img 
          src="/images/castle_hall.png" 
          alt="Dettagli storici" 
          class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-6">
          <p class="text-white font-serif text-xl">Il Salone Eventi</p>
        </div>
      </div>

      <div class="relative rounded-3xl overflow-hidden group bg-stone-300 min-h-[200px]">
        <img 
          src="/images/castle_garden.png" 
          alt="Vista sul mare" 
          class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-6">
          <p class="text-white font-serif text-xl">I Giardini Segreti</p>
        </div>
      </div>
    </div>
  </div>
</section>
