---
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="it" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <SEO title={title} description={description} />
    {/* Ottimizzazione PageSpeed estrema: Preload dell'asset LCP (Largest Contentful Paint) su Mobile/Desktop */}
    <link rel="preload" fetchpriority="high" as="image" href="/images/castle_exterior.webp" type="image/webp" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    {/* Ottimizzazione PageSpeed: Caricamento differito del CSS di Google Fonts per azzerare il Render Blocking */}
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
    </noscript>
  </head>
  <body class="bg-[#FDFBF7] text-[#121212] font-sans antialiased selection:bg-[#A44B2B] selection:text-white">
    <header class="fixed top-0 w-full z-50 transition-all duration-300 bg-white/60 backdrop-blur-md border-b border-stone-200/50">
      <nav class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between" aria-label="Navigazione Principale">
        <a href="/" class="flex flex-col group">
          <span class="font-serif text-xl tracking-wide group-hover:text-[#A44B2B] transition-colors">Castello di Muggia</span>
          <span class="text-[10px] tracking-widest uppercase text-stone-500 font-medium">Dal 1374</span>
        </a>
        <ul class="hidden md:flex items-center gap-8 text-sm font-medium text-stone-700">
          <li><a href="#storia" class="hover:text-[#A44B2B] transition-colors">Storia</a></li>
          <li><a href="#esperienze" class="hover:text-[#A44B2B] transition-colors">Esperienze</a></li>
          <li><a href="#galleria" class="hover:text-[#A44B2B] transition-colors">Galleria</a></li>
        </ul>
        <a href="#prenota" class="bg-[#A44B2B] text-white px-6 py-2.5 rounded-full text-sm font-semibold hover:bg-[#8A3F24] hover:shadow-lg transition-all duration-300">
          Prenota
        </a>
      </nav>
    </header>
    <slot />
    <Footer />

    {/* Logica di Auto-Refresh / Live Update (Soluzione Avanzata senza polling continuo) */}
    <script>
      (function() {
        // 1. Memorizza il giorno di caricamento della pagina
        const loadDate = new Date().toDateString();

        // 2. Calcola i millisecondi esatti fino alla prossima mezzanotte
        function scheduleMidnightRefresh() {
          const now = new Date();
          const midnight = new Date();
          midnight.setHours(24, 0, 0, 0); // Mezzanotte esatta
          const timeUntilMidnight = midnight.getTime() - now.getTime();

          setTimeout(() => {
            console.log("🌙 Scoccare della mezzanotte: ricaricamento automatico palinsesto Castello...");
            window.location.reload();
          }, timeUntilMidnight);
        }

        // 3. Controllo al "risveglio" della scheda (Page Visibility API)
        // Ottimo per gli utenti mobile che lasciano le tab aperte in background per giorni
        document.addEventListener("visibilitychange", () => {
          if (document.visibilityState === "visible") {
            const currentDate = new Date().toDateString();
            // Se l'utente riapre la tab in un giorno diverso da quello in cui l'ha caricata
            if (currentDate !== loadDate) {
              console.log("☀️ Riapertura tab in un nuovo giorno: sincronizzazione contenuti in corso...");
              window.location.reload();
            }
          }
        });

        // Avvia il timer di mezzanotte
        scheduleMidnightRefresh();
      })();
    </script>
  </body>
</html>

<style is:global>
  @tailwind base;
  @tailwind components;
  @tailwind utilities;
</style>
